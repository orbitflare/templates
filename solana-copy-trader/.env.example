# OrbitFlare Jetstream gRPC endpoint
ORBITFLARE_GRPC_ENDPOINT=http://fra.jetstream.orbitflare.com

# OrbitFlare RPC URL (for simulate/send/confirm)
ORBITFLARE_RPC_URL=https://rpc.orbitflare.com/v1/YOUR_API_KEY

# Path to Solana keypair file (mounted in Docker)
TRADER_KEYPAIR_PATH=/keys/trader.json

# Redis connection URL
REDIS_URL=redis://redis:6379

# PostgreSQL connection URL (for trade journal)
DATABASE_URL=postgres://copytrader:password@postgres:5432/copytrader

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Override dry-run mode (true = safe, false = live trading)
DRY_RUN=true

# Log level (trace, debug, info, warn, error)
RUST_LOG=info
